# Openverse production environment template
#
# Copy this file to `.env.production` (or whatever your deployment pipeline
# loads) and fill in the values. Anything left blank uses a randomized
# fallback so non-critical features just disable themselves.

# -----------------------------------------------------------------------
# Required: session/auth secrets. Production refuses to start if any of
# these are missing. Generate with: `openssl rand -hex 32`.
# -----------------------------------------------------------------------
INTERNAL_AUTH_TOKEN=
FOREIGN_AUTH_STATE=
GAME_ACTION_PERMISSION_TOKEN_SECRET=
UNTRUSTED_APPLY_TOKEN=

# -----------------------------------------------------------------------
# Optional: OAuth provider client secrets. Only required for the login
# methods you actually want enabled.
# -----------------------------------------------------------------------
DISCORD_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_SECRET=
TWITCH_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------
# Optional: external service API keys. Each feature is gracefully
# disabled when its key is absent.
# -----------------------------------------------------------------------
POSTMARK_AUTH_TRANSACTIONAL=   # transactional email delivery
OPENAI_API_KEY=                # NPC chat generation
ELEVENLABS_API_KEY=            # text-to-speech voices
SPLASH_RECAPTCHA_SERVER_SECRET=

# Discord bot + webhooks (optional, all OFF by default)
BIOMES_DISCORD_BOT_TOKEN=
DISCORD_NEW_USERS_WEBHOOK_URL=
DISCORD_CAMERA_WEBHOOK_URL=
DISCORD_SOCIAL_WEBHOOK_URL=
DISCORD_USER_REPORT_WEBHOOK_URL=
DISCORD_DEPLOY_WEBHOOK_URL=
DISCORD_REVIEW_WEBHOOK_URL=
DISCORD_TEST_WEBHOOK_URL=
DISCORD_BIOMES_ALPHA_WEBHOOK=

# Dev/internal tools (optional)
GITHUB_MOSSY_MUCKER_PERSONAL_ACCESS_TOKEN=
LINEAR_API_KEY=
ILL_ALCHEMY_API_KEY=
BIOMESBOB_CLIENT_SECRET=
BIOMESBOB_PRIVATE_KEY=

# -----------------------------------------------------------------------
# Cookie / domain config. If served behind HTTPS and you want the auth
# cookie scoped to a specific domain, set COOKIE_DOMAIN to that value.
# Leave blank to let the browser scope the cookie to the request host.
# -----------------------------------------------------------------------
COOKIE_DOMAIN=

# -----------------------------------------------------------------------
# Backend toggles. The defaults work for a single-box self-host.
# -----------------------------------------------------------------------
NODE_ENV=production
# Use the local filesystem instead of Google Cloud Storage (default ON):
# USE_GCS=1                    # uncomment to re-enable GCS
# Use Firestore for primary storage (default OFF):
# USE_FIRESTORE=1              # also requires FIREBASE_* below
# Send BigQuery analytics rows (default OFF):
# ENABLE_BIGQUERY=1
# Wait for GCE metadata service before starting (default OFF):
# WAIT_FOR_GCE=1

# -----------------------------------------------------------------------
# Optional: Firebase / Firestore. Only fill in if USE_FIRESTORE=1 or you
# want FCM push notifications.
# -----------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=       # raw JSON key
GOOGLE_CLOUD_PROJECT=           # used by GCS + BigQuery if enabled
GOOGLE_APPLICATION_CREDENTIALS= # path to service account JSON

# -----------------------------------------------------------------------
# Client-side env (must be NEXT_PUBLIC_*). Only set if you enabled
# Firebase Auth in the browser; otherwise the bundle just no-ops.
# -----------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
